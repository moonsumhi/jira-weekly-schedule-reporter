# ================================
# Docker Compose 빌드 인수
# ================================
# 로컬: python:3.12-slim / 내부망: x.x.x.x(HARBOR_URL)/dev/python-base:3.12-slim
BO_BASE_IMAGE=
# 로컬: false / 내부망: true
BO_SKIP_SYS_DEPS=
# 로컬: node:22-alpine / 내부망: x.x.x.x(HARBOR_URL)/dev/node-base:22-alpine
BO_FE_NODE_BASE_IMAGE=
# 로컬: nginx:alpine / 내부망: x.x.x.x(HARBOR_URL)/dev/nginx:alpine
BO_FE_NGINX_BASE_IMAGE=
# 로컬: false / 내부망: true
BO_FE_SKIP_NPM_INSTALL=

# ================================
# Harbor (내부망만 필요)
# ================================
HARBOR_URL=

# ================================
# MongoDB
# ================================
MONGO_INITDB_ROOT_USERNAME=
MONGO_INITDB_ROOT_PASSWORD=
APP_DB_NAME=
APP_DB_USER=
APP_DB_PASS=
MONGO_DATA_PATH=

# ================================
# Pilot
# ================================
PILOT_ENABLED=
GITHUB_TOKEN=
GITHUB_WEBHOOK_SECRET=
